@model Navalha_Barbearia.Models.ViewModels.AgendamentoCrudViewModel
@using Navalha_Barbearia.Enums

@{
    ViewData["Title"] = "Agendamentos";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <span class="eyebrow">Agenda</span>
            <h1 class="h3 mt-2 mb-0">Agendamentos</h1>
        </div>
        <a class="btn btn-dark" asp-action="Create">Novo agendamento</a>
    </div>

    <div class="card-soft p-3 p-md-4">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Barbeiro</th>
                        <th>Procedimento</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th>Preco</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agendamento in Model.Agendamentos)
                    {
                        var formId = $"status-form-{agendamento.IdAgendamento}";

                        <tr>
                            <td>@agendamento.Cliente.NomeCompleto</td>
                            <td>@agendamento.Barbeiro.NomeCompleto</td>
                            <td>@agendamento.Procedimento</td>
                            <td>@agendamento.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex flex-column gap-2">
                                    <form id="@formId" asp-action="AtualizarStatus" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idAgendamento" value="@agendamento.IdAgendamento" />
                                        <select name="status" class="form-select form-select-sm">
                                            @foreach (var status in Enum.GetValues<StatusAgendamentoEnum>())
                                            {
                                                <option value="@((int)status)" selected="@(agendamento.StatusAgendamentoEnum == status)">@status</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-dark btn-sm">Salvar</button>
                                    </form>
                                    <small class="text-muted">Atualizacao direta do status sem abrir a edicao completa.</small>
                                </div>
                            </td>
                            <td>@agendamento.Preco.ToString("C")</td>
                            <td class="text-end">
                                <a class="btn btn-outline-dark btn-sm" asp-controller="Agendamentos" asp-action="ResumoAgendamento" asp-route-idAgendamento="@agendamento.IdAgendamento">Detalhes</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>