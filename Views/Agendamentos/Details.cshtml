@model Navalha_Barbearia.Models.AgendamentoModel

@{
    ViewData["Title"] = "Detalhes do Agendamento";
}

<div class="container py-4">
    <div class="card-soft p-4 p-md-5 mx-auto" style="max-width: 860px;">
        <span class="eyebrow">Detalhes</span>
        <h1 class="h3 mt-3 mb-3">Detalhes do agendamento</h1>
        <p class="text-muted">Informações completas do agendamento agendado.</p>

        <dl class="row mb-0">
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.IdAgendamento</dd>
            <dt class="col-sm-4">Cliente</dt>
            <dd class="col-sm-8">@Model.Cliente.NomeCompleto</dd>
            <dt class="col-sm-4">CPF</dt>
            <dd class="col-sm-8">@Model.Cliente.CPF</dd>
            <dt class="col-sm-4">Barbeiro</dt>
            <dd class="col-sm-8">@Model.Barbeiro.NomeCompleto</dd>
            <dt class="col-sm-4">Procedimento</dt>
            <dd class="col-sm-8">@Model.Procedimento</dd>
            <dt class="col-sm-4">Data e hora</dt>
            <dd class="col-sm-8">@Model.DataHora.ToString("dd/MM/yyyy HH:mm")</dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.StatusAgendamentoEnum</dd>
            <dt class="col-sm-4">Preco</dt>
            <dd class="col-sm-8">@Model.Preco.ToString("C")</dd>
            <dt class="col-sm-4">Observacao</dt>
            <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Observacao) ? "Sem observacoes." : Model.Observacao)</dd>
        </dl>

        <div class="d-flex gap-2 pt-4">
            <a class="btn btn-dark" asp-action="Edit" asp-route-id="@Model.IdAgendamento">Editar</a>
            <a class="btn btn-outline-dark" asp-action="Index">Voltar</a>
        </div>
    </div>
</div>