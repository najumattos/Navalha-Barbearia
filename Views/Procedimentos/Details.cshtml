@model Navalha_Barbearia.Models.ProcedimentoModel

@{
    ViewData["Title"] = "Detalhes do procedimento";
}

<div class="container py-4">
    <div class="card-soft p-4 p-md-5 mx-auto" style="max-width: 760px;">
        <span class="eyebrow">Detalhes</span>
        <h1 class="h3 mt-3 mb-3">Detalhes do procedimento</h1>
        <p class="text-muted">Informacoes do item de catalogo selecionado.</p>

        <dl class="row mb-0">
            <dt class="col-sm-4">Tipo</dt>
            <dd class="col-sm-8">@Model.ProcedimentoEnum</dd>
            <dt class="col-sm-4">Descricao</dt>
            <dd class="col-sm-8">@Model.Descricao</dd>
            <dt class="col-sm-4">Preco base</dt>
            <dd class="col-sm-8">@Model.PrecoBase.ToString("C")</dd>
        </dl>

        <div class="d-flex gap-2 pt-4">
            <a class="btn btn-dark" asp-action="Edit" asp-route-procedimentoEnum="@Model.ProcedimentoEnum">Editar</a>
            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-procedimentoEnum="@Model.ProcedimentoEnum">Excluir</a>
            <a class="btn btn-outline-dark" asp-action="Index">Voltar</a>
        </div>
    </div>
</div>
