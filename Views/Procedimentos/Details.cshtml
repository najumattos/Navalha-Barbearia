@model Navalha_Barbearia.Models.ViewModels.ProcedimentoDetalhesViewModel

@{
    ViewData["Title"] = "Detalhes do procedimento";
}

<div class="container py-4">
    <div class="card-soft p-4 p-md-5 mx-auto" style="max-width: 760px;">
        <span class="eyebrow">Detalhes</span>
        <h1 class="h3 mt-3 mb-3">Detalhes do procedimento</h1>
        <p class="text-muted">Informacoes do item de catalogo selecionado.</p>

        <dl class="row mb-0">
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.Id</dd>
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>
            <dt class="col-sm-4">Descricao</dt>
            <dd class="col-sm-8">@Model.Descricao</dd>
            <dt class="col-sm-4">Preco base</dt>
            <dd class="col-sm-8">@Model.PrecoBase.ToString("C")</dd>
        </dl>

        @if (Model.PodeVisualizarPrecosPorBarbeiro)
        {
            <hr class="my-4" />
            <h2 class="h5 mb-3">Preco praticado por barbeiro</h2>
            <p class="text-muted mb-3">Transparencia de valores: cada barbeiro pode ter preco proprio para este procedimento.</p>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Barbeiro</th>
                            <th class="text-end">Preco cobrado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PrecosPorBarbeiro)
                        {
                            <tr>
                                <td>@item.NomeBarbeiro</td>
                                <td class="text-end">@item.PrecoPorBarbeiro.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="d-flex gap-2 pt-4">
            <a class="btn btn-dark" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
            <a class="btn btn-outline-dark" asp-action="Index">Voltar</a>
        </div>
    </div>
</div>
