@model Navalha_Barbearia.Models.ProcedimentoModel

@{
    ViewData["Title"] = "Novo procedimento";
}

<div class="container py-4">
    <div class="card-soft p-4 p-md-5 mx-auto" style="max-width: 760px;">
        <span class="eyebrow">Cadastro</span>
        <h1 class="h3 mt-3 mb-4">Novo procedimento</h1>

        <form asp-action="Create" method="post" class="row g-3">
            @Html.AntiForgeryToken()

            <div class="col-md-6">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="PrecoBase" class="form-label"></label>
                <input asp-for="PrecoBase" type="number" step="0.01" class="form-control" />
            </div>

            <div class="col-12">
                <label asp-for="Descricao" class="form-label"></label>
                <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
            </div>

            <div class="col-12 d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-dark">Salvar</button>
                <a class="btn btn-outline-dark" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>