@model Navalha_Barbearia.Models.ViewModels.LoginRequestViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="container py-5 login-shell">
    <div class="login-card card-soft p-4 p-md-5 mx-auto">
        <span class="eyebrow">Acesso restrito</span>
        <h1 class="h3 mt-3 mb-2">Login do usuario</h1>
        <p class="text-muted mb-4">Tela simples para acessar os perfis da aplicacao sem poluir a interface.</p>

        <form asp-action="Login" method="post" class="d-grid gap-3">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div>
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Senha" class="form-label"></label>
                <input asp-for="Senha" type="password" class="form-control" />
                <span asp-validation-for="Senha" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-dark">Entrar</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}