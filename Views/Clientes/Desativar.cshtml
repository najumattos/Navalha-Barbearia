@model Navalha_Barbearia.Models.ClienteModel

@{
    ViewData["Title"] = "Desativar cliente";
}

<div class="container py-4">
    <div class="card-soft p-4 p-md-5 mx-auto" style="max-width: 760px;">
        <span class="eyebrow">Arquivamento</span>
        <h1 class="h3 mt-3 mb-3 text-danger">Desativar cliente</h1>
        <p class="text-muted">Essa acao nao exclui o registro: o cliente sera arquivado e podera ser consultado na lista de clientes arquivados.</p>

        <dl class="row mb-0">
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.NomeCompleto</dd>
            <dt class="col-sm-4">CPF</dt>
            <dd class="col-sm-8">@Model.CPF</dd>
            <dt class="col-sm-4">Genero</dt>
            <dd class="col-sm-8">@Model.GeneroEnum.ToString()</dd>
        </dl>

        <form asp-action="Desativar" method="post" class="d-flex gap-2 pt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Desativar</button>
            <a class="btn btn-outline-dark" asp-action="Index">Cancelar</a>
        </form>
    </div>
</div>
