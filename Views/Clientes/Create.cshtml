@model Navalha_Barbearia.Models.ViewModels.ClienteCrudViewModel

@{
    ViewData["Title"] = "Novo cliente";
}

<div class="container py-4">
    <div class="card-soft p-4 p-md-5 mx-auto" style="max-width: 860px;">
        <span class="eyebrow">Cadastro</span>
        <h1 class="h3 mt-3 mb-4">Novo cliente</h1>

        <form asp-action="Create" method="post" class="row g-3">
            @Html.AntiForgeryToken()

            <div class="col-md-6">
                <label asp-for="Cliente.NomeCompleto" class="form-label"></label>
                <input asp-for="Cliente.NomeCompleto" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Cliente.Telefone" class="form-label"></label>
                <input asp-for="Cliente.Telefone" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Cliente.CPF" class="form-label"></label>
                <input asp-for="Cliente.CPF" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Cliente.GeneroEnum" class="form-label"></label>
                <select asp-for="Cliente.GeneroEnum" class="form-select" asp-items="Html.GetEnumSelectList<GeneroEnum>()"></select>
            </div>

            <div class="col-md-4">
                <label asp-for="Cliente.DataNascimento" class="form-label"></label>
                <input asp-for="Cliente.DataNascimento" type="date" class="form-control" />
            </div>

            <div class="col-12">
                <label asp-for="Cliente.Endereco" class="form-label"></label>
                <input asp-for="Cliente.Endereco" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Cliente.BarbeiroQueCadastrou.Id" class="form-label">Barbeiro cadastrado por</label>
                @if (ViewBag.PodeEscolherBarbeiro is true)
                {
                    <select asp-for="Cliente.BarbeiroQueCadastrou.Id" class="form-select">
                        <option value="">Selecione</option>
                        @foreach (var barbeiro in Model.Barbeiros)
                        {
                            <option value="@barbeiro.Id">@barbeiro.NomeCompleto</option>
                        }
                    </select>
                }
                else
                {
                    <input type="hidden" asp-for="Cliente.BarbeiroQueCadastrou.Id" value="@(Model.Barbeiros.FirstOrDefault()?.Id ?? 0)" />
                    <input class="form-control" value="@(Model.Barbeiros.FirstOrDefault()?.NomeCompleto ?? "Nao identificado")" readonly />
                    <small class="text-muted">Para funcionario, o cliente e cadastrado automaticamente para o proprio barbeiro logado.</small>
                }
            </div>

            <div class="col-12 d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-dark">Salvar</button>
                <a class="btn btn-outline-dark" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>