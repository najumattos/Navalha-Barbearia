@model Navalha_Barbearia.Models.ViewModels.ClienteDetalhesViewModel

@{
    ViewData["Title"] = "Detalhes do cliente";
}

<div class="container py-4">
    <div class="card-soft p-4 p-md-5 mx-auto" style="max-width: 860px;">
        <span class="eyebrow">Detalhes</span>
        <h1 class="h3 mt-3 mb-3">Detalhes do cliente</h1>
        <p class="text-muted">Dados completos de cadastro do cliente.</p>

        <dl class="row mb-0">
            <dt class="col-sm-4">Id</dt>
            <dd class="col-sm-8">@Model.Cliente.Id</dd>
            <dt class="col-sm-4">Nome</dt>
            <dd class="col-sm-8">@Model.Cliente.NomeCompleto</dd>
            <dt class="col-sm-4">CPF</dt>
            <dd class="col-sm-8">@Model.Cliente.CPF</dd>
            <dt class="col-sm-4">Telefone</dt>
            <dd class="col-sm-8">@Model.Cliente.Telefone</dd>
            <dt class="col-sm-4">Genero</dt>
            <dd class="col-sm-8">@Model.Cliente.GeneroEnum</dd>
            <dt class="col-sm-4">Endereco</dt>
            <dd class="col-sm-8">@Model.Cliente.Endereco</dd>
            <dt class="col-sm-4">Nascimento</dt>
            <dd class="col-sm-8">@Model.Cliente.DataNascimento.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Cadastro</dt>
            <dd class="col-sm-8">@Model.Cliente.DataCadastro.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-4">Ativo</dt>
            <dd class="col-sm-8">@(Model.Cliente.Ativo ? "Sim" : "Nao")</dd>
            <dt class="col-sm-4">Barbeiro responsavel</dt>
            <dd class="col-sm-8">@Model.Cliente.BarbeiroQueCadastrou.NomeCompleto</dd>
        </dl>

        <div class="d-flex gap-2 pt-4">
            <a class="btn btn-dark" asp-action="Edit" asp-route-id="@Model.Cliente.Id">Editar</a>
            @if (Model.Cliente.Ativo && Model.PodeDesativar)
            {
                <a class="btn btn-outline-danger" asp-action="Desativar" asp-route-id="@Model.Cliente.Id">Desativar</a>
            }
            <a class="btn btn-outline-dark" asp-action="Index">Voltar</a>
        </div>
    </div>

    <div class="card-soft p-4 p-md-5 mx-auto mt-4" style="max-width: 860px;">
        <span class="eyebrow">Historico</span>
        <h2 class="h4 mt-3 mb-3">Historico de agendamentos</h2>
        <p class="text-muted">Lista completa de agendamentos vinculados a este cliente, independente do barbeiro que realizou o atendimento.</p>

        @if (!Model.HistoricoAgendamentos.Any())
        {
            <p class="mb-0 text-muted">Nenhum agendamento encontrado para este cliente.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Barbeiro</th>
                            <th>Procedimento</th>
                            <th>Status</th>
                            <th>Preco</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agendamento in Model.HistoricoAgendamentos)
                        {
                            <tr>
                                <td>@agendamento.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@agendamento.Barbeiro.NomeCompleto</td>
                                <td>@agendamento.Procedimento</td>
                                <td>@agendamento.StatusAgendamentoEnum</td>
                                <td>@agendamento.Preco.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
