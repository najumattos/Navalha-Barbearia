@model Navalha_Barbearia.Models.ViewModels.HomeClienteViewModel

@{
    ViewData["Title"] = "Home Cliente";
    Layout = "_LayoutLogged";
}

<div class="container py-4">
    <h1 class="h3 mb-4">Area do Cliente</h1>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">Meus dados cadastrais</div>
        <div class="card-body">
            <!-- Cliente apenas visualiza os dados cadastrais, sem edicao nesta tela. -->
            <div class="row g-3">
                <div class="col-md-6">
                    <strong>Nome:</strong> @Model.Cliente.NomeCompleto
                </div>
                <div class="col-md-6">
                    <strong>CPF:</strong> @Model.Cliente.CPF
                </div>
                <div class="col-md-6">
                    <strong>Telefone:</strong> @Model.Cliente.Telefone
                </div>
                <div class="col-md-6">
                    <strong>Genero:</strong> @Model.Cliente.GeneroEnum
                </div>
                <div class="col-md-6">
                    <strong>Endereco:</strong> @Model.Cliente.Endereco
                </div>
                <div class="col-md-6">
                    <strong>Data de nascimento:</strong> @Model.Cliente.DataNascimento.ToString("dd/MM/yyyy")
                </div>
                <div class="col-md-6">
                    <strong>Data de cadastro:</strong> @Model.Cliente.DataCadastro.ToString("dd/MM/yyyy")
                </div>
            </div>
        </div>
    </div>

    <div id="meus-agendamentos" class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold">Meus agendamentos</div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Barbeiro</th>
                        <th>Procedimento</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th>Preco</th>
                        <th>Alterar status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agendamento in Model.Agendamentos)
                    {
                        <tr>
                            <td>@agendamento.Barbeiro.NomeCompleto</td>
                            <td>@agendamento.Procedimento</td>
                            <td>@agendamento.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@agendamento.StatusAgendamentoEnum</td>
                            <td>@agendamento.Preco.ToString("C")</td>
                            <td>
                                <!-- Alteracao simples e restrita: o cliente muda apenas o proprio status. -->
                                <form asp-controller="Home" asp-action="AtualizarStatusAgendamentoCliente" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="idCliente" value="@Model.Cliente.Id" />
                                    <input type="hidden" name="idAgendamento" value="@agendamento.IdAgendamento" />
                                    <select name="status" class="form-select form-select-sm">
                                        <option value="1">Cancelado</option>
                                        <option value="2">Agendado</option>
                                        <option value="3">Concluido</option>
                                        <option value="4">Pendente</option>
                                    </select>
                                    <button type="submit" class="btn btn-dark btn-sm">Salvar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>